{
  "name": "@finfolio/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=6001 tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:admin": "tsx src/db/seed-admin.ts",
    "db:generate": "cross-env NODE_OPTIONS=--import=tsx drizzle-kit generate",
    "db:migrate": "cross-env NODE_OPTIONS=--import=tsx drizzle-kit migrate",
    "db:push": "cross-env NODE_OPTIONS=--import=tsx drizzle-kit push",
    "db:studio": "cross-env NODE_OPTIONS=--import=tsx drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^8.0.3",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "decimal.js": "^10.4.3",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "node-cron": "^3.0.3",
    "openai": "^6.42.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^2.1.4",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
