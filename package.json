{
  "name": "finfolio",
  "version": "1.0.0",
  "private": true,
  "description": "FinFolio — Personal Capital Management (MVP scaffold)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "package:zip": "node scripts/package-deploy.mjs",
    "db:generate": "pnpm --filter @finfolio/api db:generate",
    "db:migrate": "pnpm --filter @finfolio/api db:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "turbo": "^2.9.15",
    "typescript": "^5.9.3",
    "yazl": "^3.3.1"
  }
}
