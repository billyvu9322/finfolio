# ---- Shared / Compose ----
NODE_ENV=development

# ---- PostgreSQL (compose service: db) ----
POSTGRES_USER=finfolio
POSTGRES_PASSWORD=finfolio
POSTGRES_DB=finfolio
# DATABASE_URL used by the API. Host is `db` inside compose, `localhost` for local dev.
DATABASE_URL=postgresql://finfolio:finfolio@localhost:5432/finfolio

# ---- API ----
API_PORT=3000
# >= 32 random chars in production
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Comma-separated allowed origins for CORS
CORS_ORIGIN=http://localhost:5173

# ---- External APIs (Phase: integration — not implemented yet) ----
OPENAI_API_KEY=
COINGECKO_API_KEY=
EXCHANGERATE_API_KEY=
REDIS_URL=

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:3000/v1
